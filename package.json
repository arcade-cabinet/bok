{
  "name": "bok",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:browser": "vitest --project browser",
    "test:unit": "vitest --project unit",
    "lint": "biome check src/",
